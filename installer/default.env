# Automyx 2.5 — Configuración de API Keys
# ==========================================
# Edita este archivo con tus API keys.
# Guarda y reinicia Automyx para aplicar cambios.
#
# NVIDIA (GRATIS — build.nvidia.com)
NVIDIA_API_KEY=

# Anthropic (claude.ai)
ANTHROPIC_API_KEY=

# OpenAI (platform.openai.com)
OPENAI_API_KEY=

# Modelo por defecto
AUTOMYX_MODEL=openai/gpt-oss-120b
