# Automyx Configuration
# Copia este archivo a .env y modifica los valores según tus necesidades

# Gateway
AUTOMYX_HOST=0.0.0.0
AUTOMYX_PORT=3500
AUTOMYX_AUTH_MODE=token  # Opciones: none, token, password
AUTOMYX_TOKEN=
AUTOMYX_PASSWORD=

# AI Models
OPENAI_API_KEY=
OLLAMA_BASE_URL=http://localhost:11434
DEFAULT_MODEL=openai/gpt-oss-120b

# ElevenLabs (Text-to-Speech)
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=EXAVITQu4vr4xnSDxMaL

# Channels
# WhatsApp (Configuración adicional puede ser necesaria)
# Telegram (Bot token desde @BotFather)
TELEGRAM_BOT_TOKEN=
